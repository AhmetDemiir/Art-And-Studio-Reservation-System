@model Online_Art_Gallery_and_Studio_Reservation_System.Models.ViewModels.ArtworkManageViewModel
@{
    ViewData["Title"] = "Yeni Eser Ekle";
}

<h1 class="h4 mb-3">Yeni Eser Ekle</h1>

<form asp-action="Create" method="post" class="card card-body shadow-sm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Title" class="form-label">Eser Adı</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Price" class="form-label">Fiyat</label>
            <input asp-for="Price" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="StockQuantity" class="form-label">Stok</label>
            <input asp-for="StockQuantity" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="ArtistId" class="form-label">Sanatçı</label>
            <select asp-for="ArtistId" asp-items="ViewBag.Artists" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="ArtworkCategoryId" class="form-label">Kategori</label>
            <select asp-for="ArtworkCategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label">Açıklama</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-8">
            <label asp-for="PrimaryImageUrl" class="form-label">Birincil Görsel URL</label>
            <input asp-for="PrimaryImageUrl" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="PrimaryImageAltText" class="form-label">Görsel Alt Metin</label>
            <input asp-for="PrimaryImageAltText" class="form-control" />
        </div>
        <div class="col-12 form-check ms-2">
            <input asp-for="IsForSale" class="form-check-input" />
            <label asp-for="IsForSale" class="form-check-label">Satışta</label>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-dark">Kaydet</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a>
    </div>
</form>
