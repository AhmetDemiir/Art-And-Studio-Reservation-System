@model IEnumerable<Online_Art_Gallery_and_Studio_Reservation_System.Models.Artwork>
@{
    ViewData["Title"] = "Eserler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Eserler</h1>
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted">@Model.Count() eser listeleniyor</span>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="Favorites" class="btn btn-outline-dark btn-sm">Favorilerim</a>
        }
    </div>
</div>

<div class="row g-4">
    @foreach (var artwork in Model)
    {
        var imageUrl = artwork.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl
            ?? artwork.Images.FirstOrDefault()?.ImageUrl
            ?? "https://via.placeholder.com/800x500?text=Artwork";
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <img src="@imageUrl" class="card-img-top" alt="@artwork.Title" style="height: 220px; object-fit: cover;" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@artwork.Title</h5>
                    <p class="text-muted mb-1">@artwork.Artist.FullName</p>
                    <p class="mb-2"><small class="text-muted">@artwork.ArtworkCategory.Name</small></p>
                    <p class="card-text text-truncate">@artwork.Description</p>
                    <p class="fw-semibold mt-auto">@artwork.Price.ToString("C0")</p>
                    <div class="d-grid gap-2">
                        <a asp-action="Details" asp-route-id="@artwork.ArtworkId" class="btn btn-dark">Detayları Gör</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Compare" asp-action="AddArtwork" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="artworkId" value="@artwork.ArtworkId" />
                                <button type="submit" class="btn btn-outline-secondary w-100">Karşılaştırmaya Ekle</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
