@model IEnumerable<Online_Art_Gallery_and_Studio_Reservation_System.Models.SupportTicket>
@{
    ViewData["Title"] = "Destek Taleplerim";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Destek Taleplerim</h1>
    <a asp-action="Create" class="btn btn-dark">Yeni Talep</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Henüz oluşturulmuş destek talebiniz bulunmuyor.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Konu</th>
                    <th>Durum</th>
                    <th>Oluşturma</th>
                    <th class="text-end">Mesaj</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td>@ticket.Subject</td>
                        <td><span class="badge bg-secondary">@ticket.Status</span></td>
                        <td>@ticket.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                        <td class="text-end">@ticket.Messages.Count</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@ticket.SupportTicketId" class="btn btn-sm btn-outline-dark">Görüntüle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
