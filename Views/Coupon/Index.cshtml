@model IEnumerable<Online_Art_Gallery_and_Studio_Reservation_System.Models.Coupon>
@{
    ViewData["Title"] = "Kupon Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Kupon ve Kampanya Yönetimi</h1>
    <a asp-action="Create" class="btn btn-dark">Yeni Kupon</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Kod</th>
                <th>Indirim</th>
                <th>Min. Tutar</th>
                <th>Kullanim</th>
                <th>Gecerlilik</th>
                <th>Durum</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var coupon in Model)
            {
                <tr>
                    <td><strong>@coupon.Code</strong></td>
                    <td>
                        @(coupon.IsPercentage ? $"{coupon.DiscountValue:0.##}%" : coupon.DiscountValue.ToString("C0"))
                    </td>
                    <td>@(coupon.MinimumOrderAmount?.ToString("C0") ?? "-")</td>
                    <td>
                        @coupon.CurrentUsageCount
                        @if (coupon.MaxUsageCount.HasValue)
                        {
                            <text>/ @coupon.MaxUsageCount.Value</text>
                        }
                    </td>
                    <td>@coupon.ValidFrom.ToLocalTime().ToString("dd MMM yyyy") - @coupon.ValidTo.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>
                        <span class="badge @(coupon.IsActive ? "bg-success" : "bg-secondary")">
                            @(coupon.IsActive ? "Aktif" : "Pasif")
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
