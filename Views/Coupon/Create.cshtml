@model Online_Art_Gallery_and_Studio_Reservation_System.Models.ViewModels.CouponCreateViewModel
@{
    ViewData["Title"] = "Yeni Kupon Oluştur";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h4 mb-3">Yeni Kupon Oluştur</h1>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label">Kupon Kodu</label>
                            <input asp-for="Code" class="form-control" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ValidTo" class="form-label">Bitis Tarihi</label>
                            <input asp-for="ValidTo" type="datetime-local" class="form-control" value="@Model.ValidTo.ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="ValidTo" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Aciklama</label>
                            <input asp-for="Description" class="form-control" />
                        </div>
                        <div class="col-md-4 form-check ms-2">
                            <input asp-for="IsPercentage" class="form-check-input" />
                            <label asp-for="IsPercentage" class="form-check-label">Yuzde Indirim</label>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DiscountValue" class="form-label">Indirim Degeri</label>
                            <input asp-for="DiscountValue" class="form-control" />
                            <span asp-validation-for="DiscountValue" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxDiscountAmount" class="form-label">Max Indirim</label>
                            <input asp-for="MaxDiscountAmount" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MinimumOrderAmount" class="form-label">Minimum Sepet Tutarı</label>
                            <input asp-for="MinimumOrderAmount" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxUsageCount" class="form-label">Maksimum Kullanim</label>
                            <input asp-for="MaxUsageCount" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-dark">Kuponu Kaydet</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Listeye Don</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
