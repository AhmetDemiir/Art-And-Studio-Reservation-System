@model IEnumerable<Online_Art_Gallery_and_Studio_Reservation_System.Models.Order>
@{
    ViewData["Title"] = "Sipariş Raporu";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Satın Alım Raporu</h1>
    <a asp-action="Dashboard" class="btn btn-outline-dark">Yönetim Paneli</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Sipariş No</th>
                <th>Kullanıcı</th>
                <th>Eserler</th>
                <th class="text-end">Toplam</th>
                <th>Tarih</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderNumber</td>
                    <td>@order.User.FullName</td>
                    <td>
                        @foreach (var item in order.OrderItems)
                        {
                            <div>@item.Artwork.Title</div>
                        }
                    </td>
                    <td class="text-end">@order.TotalAmount.ToString("C0")</td>
                    <td>@order.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
